# Database
POSTGRES_HOST=localhost
DB_PORT=5432
POSTGRES_DB=art_gallery
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Mail
MAIL_HOST=localhost
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# JWT
JWT_SECRET=your_256bit_hex_secret_here
JWT_EXPIRE_AFTER=720

# OTP
OTP_SALT=your_bcrypt_salt_here

# Chapa Payment
CHAPA_SECRET_KEY=CHASECK_TEST-your_key_here

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here

# File Storage
BASE_FOLDER=/path/to/uploads

# Seed Users (used only on initial startup)
SEED_ADMIN_PASSWORD=change_me_admin
SEED_CUSTOMER_PASSWORD=change_me_customer
